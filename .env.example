# WebSocket Configuration
# Production: wss://api.forkoff.app
# For local dev, use your machine's IP: ws://192.168.x.x:3000
EXPO_PUBLIC_WS_URL=wss://api.forkoff.app

# Supabase Configuration
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Feature Flags
# Set to 'true' to use mock data (for testing without backend)
EXPO_PUBLIC_USE_MOCKS=false

# EAS Project ID (from Expo dashboard, only needed for EAS builds)
EXPO_PUBLIC_PROJECT_ID=your-eas-project-id

# PostHog Analytics (optional — app works without it)
EXPO_PUBLIC_POSTHOG_API_KEY=your-posthog-api-key

# Sentry Error Tracking (optional — app works without it)
EXPO_PUBLIC_SENTRY_DSN=your-sentry-dsn
